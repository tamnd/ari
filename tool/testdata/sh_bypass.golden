ls && rm -rf /                                => ["ls", "rm -rf /"]
FOO=bar rm -rf /                              => ["rm -rf /"]
A=1 B=2 git push                              => ["git push"]
nohup git push                                => ["git push"]
timeout 30 git push                           => ["git push"]
timeout -k 5 30 git push                      => ["git push"]
nice -n 10 make                               => ["make"]
env A=1 git push                              => ["git push"]
env FOO=bar nohup nice -n 5 rm -rf /tmp/x     => ["rm -rf /tmp/x"]
echo "a && b"                                 => ["echo \"a && b\""]
echo 'x; rm -rf /'                            => ["echo 'x; rm -rf /'"]
cat f | grep x                                => ["cat f", "grep x"]
echo hi > /etc/passwd                         => ["echo hi"]
git push 2>&1 | tee log                       => ["git push", "tee log"]
time go test ./...                            => ["go test ./..."]
a; b; c                                       => ["a", "b", "c"]
x || y                                        => ["x", "y"]
make >> build.log 2>&1                        => ["make"]
